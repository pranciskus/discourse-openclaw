{
  "name": "openclaw-discourse",
  "version": "0.1.0",
  "description": "OpenClaw plugin for Discourse forum integration — read, search, filter, and write topics/posts via agent tools",
  "type": "module",
  "license": "MIT",
  "author": "pranciskus",
  "repository": {
    "type": "git",
    "url": "https://github.com/pranciskus/discourse-openclaw"
  },
  "keywords": [
    "openclaw-plugin",
    "discourse",
    "ai-agents",
    "discourse-api",
    "openclaw"
  ],
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "install": {
      "npmSpec": "openclaw-discourse",
      "defaultChoice": "npm"
    }
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  }
}
